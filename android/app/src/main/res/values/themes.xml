<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Compose renders the real UI; this window theme only controls the pre-Compose
         window background and the (absent) action bar. -->
    <style name="Theme.Flowtime" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/flow_background</item>
        <item name="android:statusBarColor">@color/flow_background</item>
        <item name="android:navigationBarColor">@color/flow_background</item>
    </style>
</resources>
