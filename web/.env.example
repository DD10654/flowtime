# Local SQLite database — used ONLY by the Prisma CLI (migrate/studio/shadow DB),
# not at runtime. Postgres-ready: swap provider + this URL.
DATABASE_URL="file:./dev.db"

# Turso (cloud libSQL) — required at runtime. The app connects here via the
# Prisma libSQL adapter (lib/db.ts). Get the token from the Turso dashboard
# (database → Create Token) or `turso db tokens create <db>`.
TURSO_DATABASE_URL="libsql://<your-db>.turso.io"
TURSO_AUTH_TOKEN=

# Optional — enables the Groq-powered LLM features (natural-language entry,
# "plan my day" command, daily insights, smart prioritization).
# The app works fully on the rule-based engine without this key.
# Get a free key at https://console.groq.com
GROQ_API_KEY=
